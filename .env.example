# ── OpenAI（必填，Step 2/3/4 皆需要）──────────────────
OPENAI_API_KEY=sk-...your-openai-api-key-here

# ── Notion（必填）────────────────────────────────────
NOTION_TOKEN=ntn_your_notion_integration_secret
# 你的母頁面 ID（可能是 Page ID 或 Database ID；本專案會自動偵測）
NOTION_PARENT_PAGE_ID=your_parent_page_or_database_id
# [可選] 最大 block 遞迴深度（預設 3；增量 fetch 時可設更低如 1-2）
NOTION_BLOCK_MAX_DEPTH=3
OPENAI_MODEL=gpt-5.2
# 用於步驟 3（Embedding 去重）
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# [可選] 分類模型（預設 gpt-5-mini，選擇題性質，mini 夠用）
# CLASSIFY_MODEL=gpt-5-mini
# [可選] Eval Judge 模型
# EVAL_JUDGE_MODEL=gpt-5-mini
# [可選] Rerank 決策模型
# EVAL_RERANK_MODEL=gpt-5-nano

# API Key 認證（Phase A）— 生產環境必須設定
# openssl rand -hex 32 可生成安全的隨機 key
SEO_API_KEY=your-secret-api-key-here

# 步驟 4：SEO 指標試算表（Google Sheets）
# 需設為「任何知道連結者可檢視」；留空則使用 config.py 內的 DEFAULT_SHEETS_URL
# SHEETS_URL=https://docs.google.com/spreadsheets/d/your_sheet_id

# ── Anthropic（可選，Reranker 用）────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── RAG 搜尋參數（可選）──────────────────────────────
# CONTEXT_EMBEDDING_WEIGHT=0.6
# RERANKER_ENABLED=auto

# ── Laminar observability (https://laminar.sh) ───────
LMNR_PROJECT_API_KEY=your_laminar_project_api_key
