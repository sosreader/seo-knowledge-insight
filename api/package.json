{
  "name": "seo-knowledge-insight-api",
  "version": "1.0.0",
  "description": "SEO Knowledge Insight API (Hono + TypeScript)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "eval:semantic": "tsx scripts/eval-semantic.ts"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.15.1",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1.19.10",
    "@hono/zod-validator": "^0.7.6",
    "@lmnr-ai/lmnr": "^0.8.14",
    "@scalar/hono-api-reference": "^0.10.0",
    "dotenv": "^17.3.1",
    "hono": "^4.12.7",
    "openai": "^6.25.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
