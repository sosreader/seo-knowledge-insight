# API Server
PORT=8002
HOST=0.0.0.0

# Security
API_KEY=your-api-key-here

# OpenAI (for embedding + chat)
OPENAI_API_KEY=your-openai-api-key-here
# CHAT_MODEL=gpt-5-mini  # 可降至 mini 節省成本（預設 gpt-5.2）

# Data paths (relative to project root)
OUTPUT_DIR=../output
SCRIPTS_DIR=../scripts

# Laminar observability (https://laminar.sh)
LMNR_PROJECT_API_KEY=your_laminar_project_api_key

# Anthropic (Claude as chat LLM)
# ANTHROPIC_API_KEY=sk-ant-...
# CHAT_LLM_PROVIDER=anthropic        # 使用 Claude 生成 chat 回答（預設 openai）
# CHAT_ANTHROPIC_MODEL=claude-sonnet-4-5  # Claude 模型（預設 claude-sonnet-4-5）

# Rate limiting
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_CHAT=20
RATE_LIMIT_GENERATE=5
